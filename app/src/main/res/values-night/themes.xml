<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.VdvCount" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/color_primary_200</item>
        <item name="colorPrimaryDark">@color/gray</item>
        <item name="colorSecondary">@color/color_secondary_200</item>

        <item name="defaultIconColor">@color/color_secondary_200</item>
    </style>

    <style name="Theme.VdvCount.Toolbar" parent="Theme.VdvCount">
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/white</item>
        <item name="popupTheme">@style/ThemeOverlay.VdvCount.Toolbar.Popup</item>
        <item name="android:popupTheme">@style/ThemeOverlay.VdvCount.Toolbar.Popup</item>
    </style>

    <style name="ThemeOverlay.VdvCount.Toolbar.Popup" parent="ThemeOverlay.MaterialComponents">
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/white</item>
    </style>

</resources>